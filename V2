            startOfWeek.setHours(0,0,0,0);

            const endOfWeek = new Date(startOfWeek);
            endOfWeek.setDate(startOfWeek.getDate() + 6);

            const thisWeekActivities = activities.filter(a => {
                const d = new Date(a.date);
                return d >= startOfWeek && d <= endOfWeek && a.registeredBy === currentUser.name;
            });

            const thisMonthMyActs = activities.filter(a => 
                a.registeredBy === currentUser.name && 
                new Date(a.date).getMonth() === currentMonth &&
                new Date(a.date).getFullYear() === currentYear
            );

            const courseCounts = {};
            thisMonthMyActs.forEach(a => {
                courseCounts[a.course] = (courseCounts[a.course] || 0) + 1;
            });

            const productCountThisMonth = {};
            thisMonthMyActs.forEach(a => {
                a.products.forEach(p => {
                    productCountThisMonth[p] = (productCountThisMonth[p] || 0) + 1;
                });
            });
            const topProductsThisMonth = Object.entries(productCountThisMonth)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 5);

            const weeklyData = [];
            for (let i = 0; i < 4; i++) {
                const weekStart = new Date(now);
                weekStart.setDate(now.getDate() - now.getDay() + 1 - (i * 7));
                weekStart.setHours(0,0,0,0);
                
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekStart.getDate() + 6);

                const weekActs = activities.filter(a => {
                    const d = new Date(a.date);
                    return d >= weekStart && d <= weekEnd && a.registeredBy === currentUser.name;
                });

                const firstDayOfMonth = new Date(weekStart.getFullYear(), weekStart.getMonth(), 1).getDay();
                const weekOfMonth = Math.ceil((weekStart.getDate() + firstDayOfMonth) / 7);
                const weekLabelText = `${weekStart.getMonth() + 1}월 ${weekOfMonth}째주`;

                weeklyData.push({
                    weekLabel: weekLabelText,
                    count: weekActs.length,
                    activities: weekActs
                });
