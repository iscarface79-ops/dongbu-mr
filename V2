    <!-- Firebase Firestore SDK: Netlify는 그대로 사용하고, 데이터만 Firestore에 저장합니다. -->
    <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-auth-compat.js"></script>

    <script>
        // Tailwind 설정
        function initTailwind() {
            document.documentElement.style.setProperty('--accent', '#14b8a6');
        }

        // ===== 데이터 =====
        let currentUser = null;
        let activities = [];
        let notices = [];
        let users = [];
        let currentTab = 'home';

        // ===== Firebase Firestore 설정 =====
        // Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 > Firebase SDK snippet > 구성(config)을 아래 값으로 교체하세요.
        // apiKey는 비밀번호가 아니지만, Firestore 보안 규칙은 반드시 설정해야 합니다.
        const firebaseConfig = {
            apiKey: "AIzaSyDLrfBj9zObzo_UisOHGKuBLsQX6Dqr1kY",
            authDomain: "dongbu-mr-pwa.firebaseapp.com",
            projectId: "dongbu-mr-pwa",
            storageBucket: "dongbu-mr-pwa.firebasestorage.app",
            messagingSenderId: "70068219821",
            appId: "1:70068219821:web:601eca7cab893d5d7a3b24"
        };

        let db = null;
        let auth = null;
        let useFirestore = false;
        let firebaseAuthReady = false;
        let firstActivitiesSnapshot = true;
        let firstNoticesSnapshot = true;

        function isFirebaseConfigReady() {
            return firebaseConfig.apiKey && !firebaseConfig.apiKey.startsWith('YOUR_') &&
                   firebaseConfig.projectId && !firebaseConfig.projectId.startsWith('YOUR_');
        }

        async function initFirebase() {
            if (!isFirebaseConfigReady()) {
                console.warn('Firebase 설정값이 아직 입력되지 않았습니다. 현재는 localStorage 모드로 동작합니다.');
                return false;
            }

            try {
                if (!firebase.apps.length) {
                    firebase.initializeApp(firebaseConfig);
                }

                db = firebase.firestore();
                auth = firebase.auth();

                try {
                    db.settings({ ignoreUndefinedProperties: true });
                } catch (settingsError) {
                    console.warn('Firestore settings 적용 생략:', settingsError);
                }

                // Firestore 보안 규칙을 request.auth != null 기반으로 바꾸기 위한 익명 인증입니다.
                // Firebase 콘솔 > Authentication > Sign-in method > 익명 로그인을 먼저 사용 설정해야 합니다.
                if (!auth.currentUser) {
                    await auth.signInAnonymously();
                }

                firebaseAuthReady = !!auth.currentUser;
                useFirestore = true;
                console.log('Firebase 익명 인증 완료:', auth.currentUser ? auth.currentUser.uid : 'unknown');
                return true;
            } catch (error) {
                console.error('Firebase 초기화 또는 인증 실패:', error);
                firebaseAuthReady = false;
                useFirestore = false;
                alert(
                    'Firebase 인증 초기화 중 오류가 발생했습니다.\n\n' +
                    'Firebase 콘솔에서 Authentication > Sign-in method > 익명 로그인을 사용 설정했는지 확인해주세요.' +
                    getErrorMessage(error)
                );
                return false;
            }
        }

        function normalizeDoc(doc) {
            return { id: doc.id, ...doc.data() };
        }

        function cleanForFirestore(value) {
            if (Array.isArray(value)) {
                return value.map(cleanForFirestore);
            }
            if (value && typeof value === 'object') {
                const cleaned = {};
                Object.entries(value).forEach(([key, val]) => {
                    if (val !== undefined) {
                        cleaned[key] = cleanForFirestore(val);
                    }
                });
                return cleaned;
            }
            return value;
        }

        function getErrorMessage(error) {
            if (!error) return '';
            const parts = [];
            if (error.code) parts.push(`오류 코드: ${error.code}`);
            if (error.message) parts.push(error.message);
            return parts.length ? '\n\n' + parts.join('\n') : '';
        }


        function getTodayString() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function formatKoreanDate(value) {
            if (!value) return '';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return String(value);
            return date.toLocaleDateString('ko-KR');
        }

        function safeText(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function safeList(values) {
            return Array.isArray(values) ? values.map(safeText).join(', ') : '';
        }

        function handleFirestoreError(action, error) {
            console.error(`${action} 실패:`, error);
            alert(`${action} 중 오류가 발생했습니다. Firestore 규칙과 Firebase 설정을 확인해주세요.${getErrorMessage(error)}`);
        }

        function rerenderAfterRemoteUpdate() {
            const mainApp = document.getElementById('main-app');
            if (mainApp && !mainApp.classList.contains('hidden')) {
                renderCurrentTab();
            }
        }

        function startRealtimeSync() {
            if (!useFirestore || !db) return Promise.resolve();

            const waitUsers = new Promise(resolve => {
                db.collection('users').orderBy('name').onSnapshot(snapshot => {
                    users = snapshot.docs.map(normalizeDoc);
                    renderUserList();
                    resolve();
                }, error => {
                    console.error('users 실시간 동기화 실패:', error);
                    resolve();
                });
            });

            const waitActivities = new Promise(resolve => {
                db.collection('activities').orderBy('createdAt', 'desc').onSnapshot(snapshot => {
                    const changes = snapshot.docChanges().map(change => ({ type: change.type, data: normalizeDoc(change.doc) }));
                    activities = snapshot.docs.map(normalizeDoc);

                    if (!firstActivitiesSnapshot) {
                        changes.forEach(change => {
                            const act = change.data;
                            if (change.type === 'added' && currentUser && act.registeredBy !== currentUser.name) {
                                showLocalNotification(
                                    '새 신규활동 등록',
                                    `${act.registeredBy || '팀원'}님이 ${act.course || ''}에 신규활동을 등록했습니다.`,
                                    'activity'
                                );
                            }
                        });
                        rerenderAfterRemoteUpdate();
                    }
                    firstActivitiesSnapshot = false;
                    resolve();
                }, error => {
                    console.error('activities 실시간 동기화 실패:', error);
                    resolve();
                });
            });

            const waitNotices = new Promise(resolve => {
                db.collection('notices').orderBy('createdAt', 'desc').onSnapshot(snapshot => {
                    const changes = snapshot.docChanges().map(change => ({ type: change.type, data: normalizeDoc(change.doc) }));
                    notices = snapshot.docs.map(normalizeDoc);

                    if (!firstNoticesSnapshot) {
                        changes.forEach(change => {
                            const notice = change.data;
                            if (change.type === 'added' && currentUser && notice.createdBy !== currentUser.name) {
                                showLocalNotification(
                                    notice.important ? '중요 공지사항 등록' : '새 공지사항 등록',
                                    `${notice.createdBy || '팀원'}님이 새 공지사항을 등록했습니다.`,
                                    'notice'
                                );
                            }
                        });
                        rerenderAfterRemoteUpdate();
                    }
                    firstNoticesSnapshot = false;
                    resolve();
                }, error => {
                    console.error('notices 실시간 동기화 실패:', error);
                    resolve();
                });
            });

            return Promise.all([waitUsers, waitActivities, waitNotices]);
        }

        // 로컬스토리지는 로그인 유지용으로만 사용합니다. Firestore 설정 전에는 예전 방식으로도 동작합니다.
        function loadData() {
            const savedCurrentUser = localStorage.getItem('dongbu_current_user');
            if (savedCurrentUser) currentUser = JSON.parse(savedCurrentUser);

            if (!isFirebaseConfigReady()) {
                const savedUsers = localStorage.getItem('dongbu_users');
                const savedActivities = localStorage.getItem('dongbu_activities');
                const savedNotices = localStorage.getItem('dongbu_notices');
                if (savedUsers) users = JSON.parse(savedUsers);
                if (savedActivities) activities = JSON.parse(savedActivities);
                if (savedNotices) notices = JSON.parse(savedNotices);
            }
        }

        function saveData() {
            if (currentUser) {
                localStorage.setItem('dongbu_current_user', JSON.stringify(currentUser));
            }

            if (!useFirestore) {
                localStorage.setItem('dongbu_users', JSON.stringify(users));
                localStorage.setItem('dongbu_activities', JSON.stringify(activities));
                localStorage.setItem('dongbu_notices', JSON.stringify(notices));
            }
        }

        // ===== 인증 관련 =====
        function switchAuthMode(mode) {
            const loginForm = document.getElementById('login-form');
            const registerForm = document.getElementById('register-form');
            const loginTab = document.getElementById('login-tab');
            const registerTab = document.getElementById('register-tab');

            if (mode === 'login') {
                loginForm.classList.remove('hidden');
                registerForm.classList.add('hidden');
                loginTab.classList.add('bg-white', 'shadow');
                registerTab.classList.remove('bg-white', 'shadow');
            } else {
                loginForm.classList.add('hidden');
                registerForm.classList.remove('hidden');
                registerTab.classList.add('bg-white', 'shadow');
                loginTab.classList.remove('bg-white', 'shadow');
            }
        }

        function selectRole(role) {
            const mrBtn = document.getElementById('role-mr');
            const managerBtn = document.getElementById('role-manager');
            const courseWrapper = document.getElementById('course-select-wrapper');

            if (role === 'mr') {
                mrBtn.classList.add('border-teal-500', 'bg-teal-50', 'text-teal-700');
                managerBtn.classList.remove('border-teal-500', 'bg-teal-50', 'text-teal-700');
                courseWrapper.style.display = 'block';
            } else {
                managerBtn.classList.add('border-teal-500', 'bg-teal-50', 'text-teal-700');
                mrBtn.classList.remove('border-teal-500', 'bg-teal-50', 'text-teal-700');
                courseWrapper.style.display = 'none';
            }
        }

        async function register() {
            const name = document.getElementById('reg-name').value.trim();
            const role = document.getElementById('role-mr').classList.contains('bg-teal-50') ? 'mr' : 'manager';
            const course = role === 'mr' ? document.getElementById('reg-course').value : null;

            if (!name) {
                alert('이름을 입력해주세요.');
                return;
            }

            if (users.find(u => u.name === name)) {
                alert('이미 등록된 이름입니다.');
                return;
            }

            const newUser = {
                id: 'u' + Date.now(),
                name: name,
                role: role,
                course: course,
                createdAt: new Date().toISOString()
            };

            try {
                if (useFirestore) {
                    await db.collection('users').doc(newUser.id).set(cleanForFirestore(newUser));
                } else {
                    users.push(newUser);
                }

                // 자동 로그인
                currentUser = newUser;
                saveData();
                showMainApp();
            } catch (error) {
                handleFirestoreError('회원가입 저장', error);
            }
        }

        function login() {
            const name = document.getElementById('login-name').value.trim();
            const user = users.find(u => u.name === name);

            if (!user) {
                alert('등록되지 않은 사용자입니다. 회원가입을 먼저 해주세요.');
                return;
