        function saveActivity() {
            const isManager = currentUser.role === 'manager';
            const course = isManager 
                ? document.getElementById('activity-course').value 
                : currentUser.course;

            const checked = Array.from(document.querySelectorAll('.product-check:checked')).map(el => el.value);

            if (checked.length === 0) {
                alert('최소 1개 이상의 품목을 선택해주세요.');
                return;
