    // ==================== PWA 설치 버튼 (강제 표시 버전) ====================
    let deferredPrompt;
    const installBtn = document.getElementById('install-btn');

    // beforeinstallprompt 이벤트 감지 (가능한 경우에만 사용)
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        console.log('beforeinstallprompt 이벤트 발생');
    });

    // 설치 버튼 클릭 시 동작
    function installPWA() {
        if (deferredPrompt) {
            // 정상적인 설치 프롬프트 실행
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then((choiceResult) => {
                if (choiceResult.outcome === 'accepted') {
                    console.log('PWA 설치 수락');
                } else {
                    console.log('PWA 설치 거부');
                }
                deferredPrompt = null;
                if (installBtn) installBtn.classList.add('hidden');
            });
        } else {
            // beforeinstallprompt가 안 뜬 경우 안내
            alert('현재 Live Server 환경에서는 자동 설치가 제한적입니다.\n\n' +
                  '개발자 도구(F12) → Application 탭 → Manifest → Install 버튼을 클릭해서 설치해주세요.');
        }
    }

    // 로그인 성공 후 설치 버튼 표시 (showMainApp 함수에서 호출)
