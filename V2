    // 설치 완료 시 버튼 숨기기
    window.addEventListener('appinstalled', () => {
        console.log('PWA가 설치되었습니다.');
        if (installBtn) installBtn.classList.add('hidden');
    });

    // ==================== Service Worker 등록 ====================
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js?v=10')
                .then(registration => {
                    console.log('✅ Service Worker 등록 성공');
                })
                .catch(error => {
                    console.error('❌ Service Worker 등록 실패:', error);
                });
        });
    }
</script>
<script>
    // ==================== Notification API ====================

    // 알림 권한 요청 함수
    function requestNotificationPermission() {
        if (!("Notification" in window)) {
            console.log("이 브라우저는 알림을 지원하지 않습니다.");
            return;
        }

        if (Notification.permission === "default") {
            Notification.requestPermission().then(permission => {
                if (permission === "granted") {
                    console.log("알림 권한이 허용되었습니다.");
                }
            });
        }
    }

    // 알림 표시 함수
    async function showLocalNotification(title, body, clickAction = null) {
        if (!("Notification" in window)) return;
        if (Notification.permission !== "granted") return;

        const options = {
            body: body || '',
            icon: "/icons/icon-192.png",
            badge: "/icons/icon-192.png",
            tag: "dongbu-notification",
            data: {
                clickAction: clickAction || '',
                url: clickAction === 'notice' ? '/?tab=notice' : '/?tab=home'
            }
        };

        // 일부 모바일/PWA 환경에서는 new Notification()이 막혀 있습니다.
        // 이 경우 Service Worker의 showNotification()으로 표시해야 합니다.
        try {
            if ('serviceWorker' in navigator) {
                const registration = await navigator.serviceWorker.ready;
                if (registration && registration.showNotification) {
                    await registration.showNotification(title, options);
                    return;
                }
            }

            // Service Worker가 아직 준비되지 않은 데스크톱 브라우저용 예비 처리
            const notification = new Notification(title, options);
            notification.onclick = () => {
                window.focus();
                if (clickAction === 'notice') {
                    switchTab('notice');
                } else if (clickAction === 'activity') {
                    switchTab('home');
                }
                notification.close();
            };
        } catch (error) {
            console.warn('알림 표시 실패:', error);
        }
    }

    // 로그인 성공 시 알림 권한 요청 (한 번만)
    function requestPermissionOnLogin() {
        if (!("Notification" in window)) return;
        if (Notification.permission === "default") {
            setTimeout(() => {
                requestNotificationPermission();
            }, 1500);
        }
    }
</script>
