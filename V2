        function showClientInputModal(products, course) {
            const hasCustomItem = products.includes('DM') || products.includes('기타');

            const modalHTML = `
                <div id="client-modal" class="fixed inset-0 bg-black/60 z-[100] flex items-end md:items-center justify-center">
                    <div onclick="event.stopImmediatePropagation()" class="bg-white w-full max-w-[480px] rounded-t-3xl md:rounded-3xl md:m-4 p-5">
                        <h3 class="font-bold text-xl mb-1">거래처 및 품목 입력</h3>
                        <p class="text-sm text-slate-500 mb-4">거래처명과 신규 품목 정보를 입력해주세요.</p>
                        
                        <div class="space-y-4">
