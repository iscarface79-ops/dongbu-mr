                            <button onclick="closeClientModal()" 
                                    class="flex-1 py-3.5 border border-slate-200 rounded-2xl font-semibold text-slate-600">
                                취소
                            </button>
                            <button id="client-save-btn" onclick="confirmClientInput('${products.join(',')}', '${course}')" 
                                    class="flex-1 py-3.5 bg-[#0F172A] text-white font-semibold rounded-2xl">
                                저장하기
                            </button>
                        </div>
                    </div>
                </div>
            `;

            const existing = document.getElementById('client-modal');
            if (existing) existing.remove();

            document.body.insertAdjacentHTML('beforeend', modalHTML);
            
            setTimeout(() => {
                const input = document.getElementById('client-name');
                if (input) input.focus();
            }, 100);
        }

        function closeClientModal() {
            const modal = document.getElementById('client-modal');
            if (modal) modal.remove();
        }

        async function confirmClientInput(productsStr, course) {
            const saveBtn = document.getElementById('client-save-btn');
            if (saveBtn) {
                saveBtn.disabled = true;
                saveBtn.textContent = '저장 중...';
            }
            const clientName = document.getElementById('client-name').value.trim();
            const products = productsStr.split(',');

            let finalProducts = [...products];
            const customProductInput = document.getElementById('custom-product-name');
            
            if (customProductInput && customProductInput.value.trim()) {
                finalProducts = finalProducts.map(p => 
                    (p === 'DM' || p === '기타') ? customProductInput.value.trim() : p
                );
            }

            const newActivity = {
                id: 'a' + Date.now(),
                date: getTodayString(),
                course: course,
                products: finalProducts,
                client: clientName,
                memo: document.getElementById('activity-memo')?.value.trim() || '',
                registeredBy: currentUser.name,
                createdAt: new Date().toISOString()
            };

            try {
                if (useFirestore) {
                    await db.collection('activities').doc(newActivity.id).set(cleanForFirestore(newActivity));
                } else {
                    activities.unshift(newActivity);
                    saveData();
                }

                closeClientModal();
                alert('신규활동이 등록되었습니다!');
                switchTab('home');

                const notifTitle = "신규활동 등록 완료";
                const notifBody = `${safeText(currentUser.name)}님이 ${safeText(course)}에 신규활동을 등록했습니다.`;
                showLocalNotification(notifTitle, notifBody, 'activity');
            } catch (error) {
                if (saveBtn) {
                    saveBtn.disabled = false;
                    saveBtn.textContent = '저장하기';
                }
                handleFirestoreError('신규활동 저장', error);
            }
        }

        async function deleteActivity(activityId, event) {
            event.stopImmediatePropagation();

            if (!confirm('이 활동을 삭제하시겠습니까?')) {
                return;
            }

            try {
                if (useFirestore) {
                    await db.collection('activities').doc(activityId).delete();
                } else {
                    activities = activities.filter(a => a.id !== activityId);
                    saveData();
                    renderCurrentTab();
                }
            } catch (error) {
                console.error('활동 삭제 실패:', error);
                alert('활동 삭제 중 오류가 발생했습니다.' + getErrorMessage(error));
            }
        }

