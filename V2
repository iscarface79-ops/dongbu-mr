        <!-- 메인 앱 화면 -->
        <div id="main-app" class="hidden flex-1 flex flex-col">
            
            <!-- Header -->
            <header class="medical-header text-white px-5 pt-5 pb-4 sticky top-0 z-50">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="flex items-center gap-x-3">
                            <div class="w-10 h-10 rounded-2xl overflow-hidden bg-white shadow-sm flex-shrink-0">
                                <img src="/icons/icon-192.png" alt="동부MR 로고" class="w-full h-full object-cover">
