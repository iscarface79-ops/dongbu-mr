        async function submitNotice() {
            const saveBtn = document.getElementById('notice-save-btn');
            if (saveBtn) {
                saveBtn.disabled = true;
                saveBtn.textContent = '등록 중...';
            }
            const title = document.getElementById('notice-title').value.trim();
            const content = document.getElementById('notice-content').value.trim();
            const important = document.getElementById('notice-important').checked;

            if (!title) {
                alert('제목을 입력해주세요.');
                if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = '등록하기'; }
                return;
            }
            if (!content) {
                alert('내용을 입력해주세요.');
                if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = '등록하기'; }
                return;
            }

            const newNotice = {
                id: 'n' + Date.now(),
                title,
                content,
                important,
                createdBy: currentUser ? currentUser.name : '알 수 없음',
                createdAt: new Date().toISOString()
            };

            try {
                if (useFirestore) {
                    await db.collection('notices').doc(newNotice.id).set(cleanForFirestore(newNotice));
                } else {
                    notices.unshift(newNotice);
                    saveData();
                }

                closeNoticeModal();
                renderCurrentTab();

                const notifTitle = important ? "중요 공지사항 등록" : "새 공지사항 등록";
                const notifBody = `${safeText(currentUser.name)}님이 새 공지사항을 등록했습니다.`;
                showLocalNotification(notifTitle, notifBody, 'notice');
            } catch (error) {
                if (saveBtn) {
                    saveBtn.disabled = false;
                    saveBtn.textContent = '등록하기';
                }
                handleFirestoreError('공지사항 저장', error);
            }
        }

        async function deleteNotice(noticeId, event) {
            if (event) event.stopImmediatePropagation();

            if (!noticeId) {
                alert('삭제할 공지사항 ID를 찾을 수 없습니다.');
                return;
            }

            if (!confirm('이 공지사항을 삭제하시겠습니까?')) {
                return;
            }

            try {
                if (useFirestore) {
                    await db.collection('notices').doc(noticeId).delete();
                } else {
                    notices = notices.filter(n => n.id !== noticeId);
                    saveData();
                    renderCurrentTab();
                }
            } catch (error) {
                console.error('공지사항 삭제 실패:', error);
                alert('공지사항 삭제 중 오류가 발생했습니다. Firestore 규칙과 설정을 확인해주세요.' + getErrorMessage(error));
            }
        }

        // ===== 초기화 =====
        async function initApp() {
            initTailwind();
            loadData();
            await initFirebase();

            if (useFirestore && firebaseAuthReady) {
                await startRealtimeSync();
            }

            if (currentUser) {
                document.getElementById('auth-screen').classList.add('hidden');
                document.getElementById('main-app').classList.remove('hidden');
                document.getElementById('header-user-name').textContent = currentUser.name;
                document.getElementById('header-user-role').textContent = 
                    currentUser.role === 'manager' ? '팀장' : currentUser.course;
                switchTab('home');
            } else {
                document.getElementById('auth-screen').classList.remove('hidden');
                document.getElementById('main-app').classList.add('hidden');
                renderUserList();
            }
        }

        window.onload = initApp;
    </script>
